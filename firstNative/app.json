{
  "expo": {
    "name": "List Tracker",
    "slug": "ListTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/listTrackerLogo.jpg",
    "scheme": "firstnative",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mrkay33.ListTracker"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/listTrackerLogo.jpg",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mr_kay33.ListTracker"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/listTrackerLogo.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/favicon.png",
          "imageWidth": 200,
          "resizeMode": "cover",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ebbb2b3-db53-429a-bb8e-dff56d61dea0"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0ebbb2b3-db53-429a-bb8e-dff56d61dea0"
    }
  }
}
